<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MoldeMVC_Core</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MoldeMVC_Core.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark mb-3" style="background-color: #1e3a5f;">
            <div class="container-fluid">
                <a class="navbar-brand text-white" asp-area="" asp-controller="Home" asp-action="Index">MoldeMVC_Core</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.Identity?.Name == "Administrador")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="GestionPermisos" asp-action="Index">Gestión Permisos</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Personas" asp-action="Index">Personas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Carreras" asp-action="Index">Carreras</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Departamentoes" asp-action="Index">Departamentos</a>
                                </li>
                            }
                            @if (User.IsInRole("DECANO"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Estudiantes" asp-action="Index">Estudiantes</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Profesors" asp-action="Index">Profesores</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="CatalogoMaterias" asp-action="Index">Catálogo Materias</a>
                                </li>
                            }
                            @if (User.IsInRole("PLANIFICADOR"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="NrcMateriums" asp-action="Index">NRC Materias</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Matriculas" asp-action="Index">Matrículas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="NrcMateriums" asp-action="Create">Periodo Académico</a>
                                </li>
                            }
                            @if (User.IsInRole("ABOGADO"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="CatalogoMaterias" asp-action="Index">Malla Curricular</a>
                                </li>
                            }
                            @if (User.IsInRole("PROFESOR"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="NrcMateriums" asp-action="Index">Mis Materias</a>
                                </li>
                            }
                            @if (User.IsInRole("ESTUDIANTE"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-controller="Matriculas" asp-action="Index">Mis Matrículas</a>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Mi aplicación ASP.NET
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
