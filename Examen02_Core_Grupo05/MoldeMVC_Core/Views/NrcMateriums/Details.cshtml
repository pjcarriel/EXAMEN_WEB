@model MoldeMVC_Core.Models.NrcMaterium

@{
    ViewData["Title"] = "Detalle NRC";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Detalle NRC</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">NRC</dt>
        <dd class="col-sm-10">@Model?.Nrc</dd>

        <dt class="col-sm-2">Materia</dt>
        <dd class="col-sm-10">@Model?.Materia?.NombreMateria</dd>

        <dt class="col-sm-2">Profesor</dt>
        <dd class="col-sm-10">@Model?.Profesor?.Personal?.NombrePersona @Model?.Profesor?.Personal?.ApellidoPersona</dd>
    </dl>
</div>
<div>
    @if (User.IsInRole("PLANIFICADOR"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Nrc">Editar</a> <span>|</span>
    }
    <a asp-action="Index">Volver</a>
</div>
