@model IEnumerable<MoldeMVC_Core.Models.NrcMaterium>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Materia)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Profesor)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Materia.MateriaId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Profesor.ProfesorId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Nrc">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Nrc">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Nrc">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
