@{
    ViewData["Title"] = "Home Page";
}

<style>
    .home-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .home-header h1 {
        font-weight: 700;
        font-size: 1.6rem;
        margin-bottom: 0.2rem;
    }

    .home-header p {
        color: #6c757d;
        font-size: 0.95rem;
        margin: 0;
    }

    .home-card {
        border: 2px solid #1e3a5f;
        border-radius: 12px;
        padding: 1.5rem;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
    }

    .home-card:hover {
        border-color: #0d2137;
        box-shadow: 0 6px 24px rgba(30, 58, 95, 0.22);
        transform: translateY(-3px);
    }

    /* Card 1 - Integrantes */
    .card-integrantes h5 {
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 1.2rem;
    }

    .integrante-item {
        margin-bottom: 1.5rem;
    }

    .integrante-item .nombre {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.1rem;
    }

    .integrante-item .rol {
        color: #6c757d;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
    }

    .btn-facebook {
        width: 100%;
        border: 1px solid #dee2e6;
        background: white;
        color: #333;
        padding: 0.4rem;
        border-radius: 6px;
        font-size: 0.9rem;
        text-decoration: none;
        display: block;
        text-align: center;
    }

    .btn-facebook:hover {
        background-color: #f8f9fa;
        color: #333;
    }

    /* Card 2 - Perfiles */
    .card-perfiles {
        align-items: center;
        justify-content: space-around;
        gap: 1.5rem;
    }

    .perfil-bloque {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        width: 100%;
    }

    .perfil-foto {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #dee2e6;
        margin-bottom: 0.7rem;
    }

    .perfil-nombre {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 0.2rem;
    }

    .perfil-descripcion {
        color: #6c757d;
        font-size: 0.82rem;
        margin-bottom: 0.8rem;
    }

    .btn-descubrir {
        background-color: #0d6efd;
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1.2rem;
        font-size: 0.9rem;
        width: 100%;
        text-decoration: none;
        display: block;
        text-align: center;
    }

    .btn-descubrir:hover {
        background-color: #0b5ed7;
        color: white;
    }

    .perfil-divider {
        border-top: 1px solid #dee2e6;
        width: 100%;
        margin: 0.5rem 0;
    }

    /* Card 3 - Indicaciones */
    .card-indicaciones h5 {
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 1rem;
    }

    .parte-label {
        font-weight: 700;
        font-size: 0.85rem;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .indicacion-item {
        display: flex;
        align-items: flex-start;
        gap: 0.5rem;
        margin-bottom: 0.6rem;
        font-size: 0.9rem;
    }

    .indicacion-item input[type="checkbox"] {
        margin-top: 3px;
        flex-shrink: 0;
    }

    .btn-ver-mas {
        border: 1px solid #dee2e6;
        background: white;
        color: #333;
        width: 100%;
        padding: 0.4rem;
        border-radius: 6px;
        margin-top: auto;
        margin-bottom: 0.5rem;
    }

    .btn-progreso {
        background-color: #ffc107;
        color: #333;
        border: none;
        width: 100%;
        padding: 0.5rem;
        border-radius: 6px;
        font-weight: 700;
    }
</style>

<div class="home-header">
    <div>
        <h1>SESIONES</h1>
        <p>Se va realizar la exposición de sesiones, seguir las indicaciones presentadas a continuación</p>
    </div>
</div>

<hr style="border-color: #1e3a5f; border-width: 2px; margin-bottom: 1.5rem;" />

<div class="row g-3" style="align-items: stretch;">

    <!-- Card 1: Integrantes -->
    <div class="col-md-4">
        <div class="home-card card-integrantes">
            <h5>Integrantes</h5>

            <div class="integrante-item">
                <p class="nombre">Pamela Jesabel Carriel</p>
                <p class="rol">Desarrollo y diseño del proyecto</p>
                <a href="#" class="btn-facebook">Facebook »</a>
            </div>

            <div class="integrante-item">
                <p class="nombre">Alisson Nicoll Cuenca</p>
                <p class="rol">Desarrollo y diseño del proyecto</p>
                <a href="#" class="btn-facebook">Facebook »</a>
            </div>
        </div>
    </div>

    <!-- Card 2: Fotos -->
    <div class="col-md-4">
        <div class="home-card card-perfiles">

            <div class="perfil-bloque">
                <img class="perfil-foto" src="~/Imagenes/PamelaCarriel.jpeg" alt="Pamela Carriel" />
                <p class="perfil-nombre">Pamela Jesabel Carriel</p>
                <p class="perfil-descripcion">Desarrolladora — .NET Framework, ASP.NET MVC y Entity Framework.</p>
            </div>

            <div class="perfil-divider"></div>

            <div class="perfil-bloque">
                <img class="perfil-foto" src="~/Imagenes/AlissonCuenca.png" alt="Alisson Cuenca" />
                <p class="perfil-nombre">Alisson Nicoll Cuenca</p>
                <p class="perfil-descripcion">Desarrolladora — .NET Framework, ASP.NET MVC y Entity Framework.</p>
            </div>

        </div>
    </div>

    <!-- Card 3: Indicaciones -->
    <div class="col-md-4">
        <div class="home-card card-indicaciones">
            <h5>Indicaciones</h5>

            <p class="parte-label">PARTE I</p>

            <div class="indicacion-item">
                <span>1. Copiar proyecto y renombrar carpeta.</span>
            </div>
            <div class="indicacion-item">
                <span>2. Usar BD EntityBD.</span>
            </div>
            <div class="indicacion-item">
                <span>3. Registrar usuarios PEPITO, MANOTAS y PLUTARCO.</span>
            </div>
            <div class="indicacion-item">
                <span>4. Usar BD PacienteDB_Foto.</span>
            </div>

            <p class="parte-label mt-2">PARTE II</p>

            <div class="indicacion-item">
                <span>5. Vistas List y Details para Paciente, Medico y Consulta.</span>
            </div>
            <div class="indicacion-item">
                <span>6. Layout con navbar condicional.</span>
            </div>
        </div>
    </div>

</div>
