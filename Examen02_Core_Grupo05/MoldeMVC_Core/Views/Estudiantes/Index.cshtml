@model IEnumerable<MoldeMVC_Core.Models.Estudiante>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Carrera)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NivelActualEstNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Personal)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Carrera.CarreraId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NivelActualEstNavigation.NivelId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Personal.PersonalId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.EstudianteId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.EstudianteId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.EstudianteId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
