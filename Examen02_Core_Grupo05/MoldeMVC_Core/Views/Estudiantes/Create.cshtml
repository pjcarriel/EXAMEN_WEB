                <label asp-for="PersonalId" class="control-label"></label>
                <select asp-for="PersonalId" class ="form-control" asp-items="ViewBag.PersonalId"></select>
            </div>
            <div class="form-group">
                <label asp-for="CarreraId" class="control-label"></label>
                <select asp-for="CarreraId" class ="form-control" asp-items="ViewBag.CarreraId"></select>
            </div>
            <div class="form-group">
                <label asp-for="NivelActualEst" class="control-label"></label>
                <select asp-for="NivelActualEst" class ="form-control" asp-items="ViewBag.NivelActualEst"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
