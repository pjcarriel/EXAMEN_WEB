@model MoldeMVC_Core.Models.Matricula

@{
    ViewData["Title"] = "Nueva Matrícula";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Nueva Matrícula</h1>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="EstudianteId" class="control-label"><strong>Estudiante</strong></label>
                <select asp-for="EstudianteId" class="form-control" asp-items="ViewBag.EstudianteId">
                    <option value="">-- Seleccione estudiante --</option>
                </select>
                <span asp-validation-for="EstudianteId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Nrc" class="control-label"><strong>NRC - Materia</strong></label>
                <select asp-for="Nrc" class="form-control" asp-items="ViewBag.Nrc">
                    <option value="">-- Seleccione NRC --</option>
                </select>
                <span asp-validation-for="Nrc" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
