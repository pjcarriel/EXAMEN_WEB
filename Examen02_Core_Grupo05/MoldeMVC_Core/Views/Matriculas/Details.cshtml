@model MoldeMVC_Core.Models.Matricula

@{
    ViewData["Title"] = "Detalle Matrícula";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Detalle Matrícula</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Estudiante</dt>
        <dd class="col-sm-10">@Model?.Estudiante?.Personal?.NombrePersona @Model?.Estudiante?.Personal?.ApellidoPersona</dd>

        <dt class="col-sm-2">NRC</dt>
        <dd class="col-sm-10">@Model?.NrcNavigation?.Nrc</dd>

        <dt class="col-sm-2">Materia</dt>
        <dd class="col-sm-10">@Model?.NrcNavigation?.Materia?.NombreMateria</dd>
    </dl>
</div>
<div>
    @if (User.IsInRole("PLANIFICADOR"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.RegistroId">Editar</a> <span>|</span>
    }
    <a asp-action="Index">Volver</a>
</div>
